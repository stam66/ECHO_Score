#tag Events btnPreviousVideo
	#tag Event
		Sub Pressed()
		  ' *******************************************************************************
		  ' btnPreviousVideo.Pressed Event
		  ' *******************************************************************************
		  If TotalVideos = 0 Then Return
		  
		  If CurrentVideoIndex > 0 Then
		    CurrentVideoIndex = CurrentVideoIndex - 1
		  Else
		    ' At first video, wrap to last video
		    CurrentVideoIndex = TotalVideos - 1
		  End If
		  
		  DisplayCurrentVideo
		End Sub
	#tag EndEvent
#tag EndEvents
#tag Events btnNextVideo
	#tag Event
		Sub Pressed()
		  ' *******************************************************************************
		  ' btnNextVideo.Pressed Event
		  ' *******************************************************************************
		  If TotalVideos = 0 Then Return
		  
		  If CurrentVideoIndex < TotalVideos - 1 Then
		    CurrentVideoIndex = CurrentVideoIndex + 1
		  Else
		    ' At last video, wrap to first video
		    CurrentVideoIndex = 0
		  End If
		  
		  DisplayCurrentVideo
		End Sub
	#tag EndEvent
#tag EndEvents
#tag Events btnPreviousCase
	#tag Event
		Sub Pressed()
		  ' *******************************************************************************
		  ' btnPreviousCase.Pressed Event
		  ' *******************************************************************************
		  If AvailableCaseIDs.Count = 0 Then Return
		  
		  If CurrentCasePosition > 0 Then
		    CurrentCasePosition = CurrentCasePosition - 1
		  Else
		    ' Wrap to last case
		    CurrentCasePosition = AvailableCaseIDs.Count - 1
		  End If
		  
		  NavigateToCase(AvailableCaseIDs(CurrentCasePosition))
		End Sub
	#tag EndEvent
#tag EndEvents
#tag Events btnNextCase
	#tag Event
		Sub Pressed()
		  ' *******************************************************************************
		  ' btnNextCase.Pressed Event
		  ' *******************************************************************************
		  If AvailableCaseIDs.Count = 0 Then Return
		  
		  If CurrentCasePosition < AvailableCaseIDs.Count - 1 Then
		    CurrentCasePosition = CurrentCasePosition + 1
		  Else
		    ' Wrap to first case
		    CurrentCasePosition = 0
		  End If
		  
		  NavigateToCase(AvailableCaseIDs(CurrentCasePosition))
		End Sub
	#tag EndEvent
#tag EndEvents
#tag Events Button1
	#tag Event
