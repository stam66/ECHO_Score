	#tag Event
		Sub Opening()
		  ' *******************************************************************************
		  ' wc_CaseReview.Opening Event
		  ' *******************************************************************************
		  Self.EnableBackButton = True
		  Self.EnableLogoutButton = True
		  Self.SectionTitle = "Assessment Section"
		  
		  UpdateNavigation // update shell page data
		  
		  LoadAvailableCases
		  LoadCase
		  LoadExistingResponse
